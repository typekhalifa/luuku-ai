{
  "name": "luuku-ai",
  "version": "0.7.2",
  "description": "Luuku AI internal operating system",
  "main": "index.js",
  "scripts": {
    "dev:ea": "tsx luuku-ai/agents/executive-assistant/agent.ts",
    "dev:research": "tsx luuku-ai/agents/research-agent/agent.ts",
    "dev:sales": "tsx luuku-ai/agents/sales-agent/agent.ts",
    "dev:dashboard": "tsx luuku-ai/agents/dashboard/agent.ts",
    "dev:executive": "tsx luuku-ai/agents/executive-dashboard/agent.ts",
    "typecheck": "tsc --noEmit",
    "clean:logs": "powershell -Command \"if (Test-Path logs) { Remove-Item logs\\*.md -Force -ErrorAction SilentlyContinue }\""
  },
  "keywords": [
    "ai",
    "agents",
    "automation",
    "luuku-ai"
  ],
  "author": "Jean D'Amour Hagabimana",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tavily/core": "^0.7.6",
    "dotenv": "^17.4.2",
    "openai": "^6.44.0"
  }
}
