generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id         String        @id @default(uuid())
  name       String        @unique
  industry   String
  website    String?
  country    String
  city       String?
  size       CompanySize?
  status     CompanyStatus
  confidence Int
  verified   Boolean
  source     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  activities Activity[]
  contacts   Contact[]
  deals      Deal[]
}

model Contact {
  id                String     @id @default(uuid())
  companyId         String
  name              String
  email             String?
  phoneNumber       String?
  preferredLanguage String?
  department        String?
  position          String?
  verified          Boolean
  confidence        Int
  source            String
  lastVerifiedAt    DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  activities        Activity[]
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Deal {
  id                String     @id @default(uuid())
  companyId         String
  title             String
  value             Float
  currency          String
  stage             DealStage
  probability       Int
  ownerAgentId      String
  nextAction        String
  dueDate           DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  expectedCloseDate DateTime?
  lastActivityAt    DateTime?
  activities        Activity[]
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Activity {
  id          String       @id @default(uuid())
  companyId   String
  contactId   String?
  dealId      String?
  type        ActivityType
  title       String
  description String
  outcome     String?
  createdBy   String
  completed Boolean @default(false)
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
}

enum CompanyStatus {
  prospect
  qualified
  customer
  inactive
}

enum CompanySize {
  startup
  small
  medium
  enterprise
}

enum DealStage {
  lead
  qualified
  discovery
  proposal
  negotiation
  won
  lost
}

enum ActivityType {
  call
  email
  meeting
  note
  task
}
